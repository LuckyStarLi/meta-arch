      {
        "id": "persona-customer-service",
        "type": "default",
        "position": { "x": 100, "y": 50 },
        "data": {
          "label": "数字人：智能客服",
          "type": "persona",
          "config": {
            "name": "智能客服数字人",
            "avatar": "avatar_female_01",
            "description": "7x24 小时在线的智能客服数字人，提供用户咨询、业务办理服务",
            "personality": {
              "traits": {
                "openness": 0.8,
                "conscientiousness": 0.9,
                "extraversion": 0.7,
                "agreeableness": 0.9,
                "neuroticism": 0.2
              },
              "communication": {
                "tone": "friendly",
                "formality": 0.6,
                "verbosity": 0.5,
                "emoji": true,
                "language": ["zh-CN", "en-US"]
              }
            }
          }
        }
      },
      {
        "id": "agent-chatbot",
        "type": "default",
        "position": { "x": 350, "y": 50 },
        "data": {
          "label": "Agent: 对话机器人",
          "type": "agent",
          "config": {
            "name": "智能对话 Agent",
            "agentType": "llm",
            "description": "基于大模型的智能对话代理，处理用户咨询和投诉",
            "capabilities": {
              "inputs": [
                { "name": "userMessage", "type": "string", "required": true, "description": "用户消息" },
                { "name": "context", "type": "object", "required": false, "description": "对话上下文" }
              ],
              "outputs": [
                { "name": "response", "type": "string", "description": "回复内容" },
                { "name": "intent", "type": "string", "description": "识别的意图" }
              ]
            },
            "triggers": [
              { "type": "message", "config": { "messagePattern": ".*" } }
            ],
            "execution": {
              "llm": {
                "provider": "openai",
                "model": "gpt-4",
                "temperature": 0.7,
                "maxTokens": 1000,
                "systemPrompt": "你是一个专业的客服助手，负责解答用户问题"
              }
            }
          }
        }
      },
      {
        "id": "agent-recommender",
        "type": "default",
        "position": { "x": 350, "y": 180 },
        "data": {
          "label": "Agent: 个性化推荐",
          "type": "agent",
          "config": {
            "name": "个性化推荐 Agent",
            "agentType": "ml",
            "description": "基于用户行为和标签的个性化推荐引擎",
            "capabilities": {
              "inputs": [
                { "name": "userId", "type": "string", "required": true, "description": "用户 ID" },
                { "name": "context", "type": "object", "required": false, "description": "上下文信息" }
              ],
              "outputs": [
                { "name": "recommendations", "type": "array", "description": "推荐列表" }
              ]
            },
            "execution": {
              "mlModel": {
                "modelPath": "/models/collaborative_filtering.pkl",
                "inputSchema": { "userId": "string", "features": "object" },
                "outputSchema": { "items": "array", "scores": "array" }
              }
            }
          }
        }
      },
      {
        "id": "agent-fraud-detection",
        "type": "default",
        "position": { "x": 350, "y": 310 },
        "data": {
          "label": "Agent: 风控检测",
          "type": "agent",
          "config": {
            "name": "智能风控 Agent",
            "agentType": "ml",
            "description": "实时检测欺诈交易和异常行为",
            "capabilities": {
              "inputs": [
                { "name": "transaction", "type": "object", "required": true, "description": "交易信息" },
                { "name": "userHistory", "type": "object", "required": false, "description": "用户历史" }
              ],
              "outputs": [
                { "name": "riskScore", "type": "number", "description": "风险评分 0-100" },
                { "name": "isFraud", "type": "boolean", "description": "是否欺诈" }
              ]
            },
            "triggers": [
              { "type": "event", "config": { "eventPattern": "transaction.*" } }
            ]
          }
        }
      },
      {
        "id": "agent-data-analyst",
        "type": "default",
